{
    "name": "kt-html-live-preview",
    "displayName": "KT - Html Live Preview",
    "description": "Advanced live preview for HTML with instant reload, SPA support, QR codes, and modern features",
    "version": "1.0.0",
    "publisher": "tchokponolivier",
    "repository": {
        "type": "git",
        "url": "https://github.com/tchokponolivier/kt-html-live-preview"
    },
    "homepage": "https://github.com/tchokponolivier/kt-html-live-preview/blob/main/README.md",
    "bugs": {
        "url": "https://github.com/tchokponolivier/kt-html-live-preview/issues"
    },
    "license": "MIT",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Visualization",
        "Debuggers"
    ],
    "keywords": [
        "html",
        "preview",
        "live",
        "reload",
        "web",
        "development",
        "spa",
        "react",
        "vue",
        "tailwind"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "icon": "media/icon.png",
    "galleryBanner": {
        "color": "#1e1e2e",
        "theme": "dark"
    },
    "contributes": {
        "commands": [
            {
                "command": "ktHtmlLivePreview.start",
                "title": "KT Live Preview: Start Server",
                "icon": "media/start-icon.svg"
            },
            {
                "command": "ktHtmlLivePreview.stop",
                "title": "KT Live Preview: Stop Server",
                "icon": "media/stop-icon.svg"
            },
            {
                "command": "ktHtmlLivePreview.showPreview",
                "title": "KT Live Preview: Show Preview",
                "icon": "$(preview)"
            },
            {
                "command": "ktHtmlLivePreview.openExternal",
                "title": "KT Live Preview: Open in Browser",
                "icon": "$(browser)"
            },
            {
                "command": "ktHtmlLivePreview.generateQR",
                "title": "KT Live Preview: Generate QR Code",
                "icon": "$(qr-code)"
            }
        ],
        "keybindings": [
            {
                "command": "ktHtmlLivePreview.showPreview",
                "key": "ctrl+alt+v",
                "when": "editorLangId == html"
            },
            {
                "command": "ktHtmlLivePreview.openExternal",
                "key": "ctrl+alt+b",
                "when": "editorLangId == html"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "ktHtmlLivePreview.showPreview",
                    "when": "resourceLangId == html",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "command": "ktHtmlLivePreview.showPreview",
                    "when": "editorLangId == html",
                    "group": "navigation"
                },
                {
                    "command": "ktHtmlLivePreview.openExternal",
                    "when": "editorLangId == html",
                    "group": "navigation"
                },
                {
                    "command": "ktHtmlLivePreview.generateQR",
                    "when": "editorLangId == html",
                    "group": "navigation"
                }
            ],
            "explorer/context": [
                {
                    "command": "ktHtmlLivePreview.showPreview",
                    "when": "resourceLangId == html",
                    "group": "navigation"
                },
                {
                    "command": "ktHtmlLivePreview.openExternal",
                    "when": "resourceLangId == html",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "title": "KT Html Live Preview",
            "properties": {
                "ktHtmlLivePreview.port": {
                    "type": "number",
                    "default": 5500,
                    "description": "Port for the live preview server (will auto-increment if taken)"
                },
                "ktHtmlLivePreview.https": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable HTTPS with self-signed certificate"
                },
                "ktHtmlLivePreview.autoReload": {
                    "type": "boolean",
                    "default": true,
                    "description": "Auto-reload browser when files change"
                },
                "ktHtmlLivePreview.externalUrls": {
                    "type": "boolean",
                    "default": false,
                    "description": "Allow access from other devices on network"
                },
                "ktHtmlLivePreview.spaMode": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable SPA mode (serve index.html for all routes)"
                },
                "ktHtmlLivePreview.frameworks": {
                    "type": "array",
                    "default": [],
                    "description": "Enable framework-specific features",
                    "items": {
                        "type": "string",
                        "enum": ["react", "vue", "angular", "tailwind", "alpinejs"]
                    }
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "publish": "vsce publish",
        "publish-patch": "vsce publish patch",
        "publish-minor": "vsce publish minor",
        "publish-major": "vsce publish major"
    },
    "devDependencies": {
        "@types/chokidar": "^2.1.3",
        "@types/express": "^4.17.17",
        "@types/mime-types": "^2.1.1",
        "@types/node": "16.x",
        "@types/qrcode": "^1.5.0",
        "@types/vscode": "^1.75.0",
        "@types/ws": "^8.5.4",
        "@vscode/vsce": "^2.19.0",
        "typescript": "^4.9.4"
    },
    "dependencies": {
        "chokidar": "^3.5.3",
        "express": "^4.18.2",
        "mime-types": "^2.1.35",
        "qrcode": "^1.5.1",
        "ws": "^8.12.0"
    }
}